{
  "output_dir": "output/synthetic-dialogue",
  "llm": {
    "api_base": "https://api.z.ai/api/anthropic",
    "model": "glm-4.5-air",
    "max_tokens": 8192
  },
  "llm_backends": [
    {
      "name": "zai",
      "type": "anthropic",
      "api_base": "https://api.z.ai/api/anthropic",
      "model": "glm-4.5-air",
      "max_tokens": 8192
    },
    {
      "name": "qwen3",
      "type": "openai",
      "api_base": "http://localhost:8900/v1",
      "model": "Scicom-intl/Qwen3-30B-A3B-Instruct-2507-Malaysian",
      "max_tokens": 4096
    }
  ],
  "tts": {
    "servers": [
      {
        "url": "http://localhost:8881",
        "max_concurrent": 32
      }
    ],
    "default_temperature": 0.3,
    "target_lufs": -23.0,
    "trim_front_seconds": 0.0,
    "max_concurrent": 8,
    "voice_pools": {
      "male": [
        "anwar",
        "Farid_595",
        "hendrick-6",
        "wafiy_5"
      ],
      "female": [
        "Dania_0",
        "Pearl_Happy",
        "NorinaYahya",
        "SitiNora"
      ]
    },
    "default_genders": {
      "agent": "male",
      "human": "female"
    }
  },
  "asr": {
    "model": "large-v3",
    "language": "ms",
    "device": "cuda",
    "compute_type": "float16",
    "align_model": "mesolitica/wav2vec2-xls-r-300m-mixed",
